{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash

# Usage:
#   In Steam launch options, put
#
#   rungame %command%

set -x

FIXEDWRAPPERS=(
    game-performance
    prime-run
)

hyprexec() {
    hyprctl dispatch exec -- "$@"
}

calculate-current-DnD() {
    local status_holder="$1" retries=10
    : >"$status_holder"
    hyprexec DNDSTATUS="$status_holder" DnD get
    until [[ -s $status_holder || $retries == 0 ]]; do
        sleep 1
        ((retries--))
    done
    [[ -s $status_holder ]]
}

pre() {
    #    local hyprgamemode
    #    hyprgamemode="$(hyprctl -j getoption animations:enabled | jq -r '.set')"
    #    if $hyprgamemode; then
    #        hyprctl --batch "\
    #            keyword animations:enabled 0; \
    #            keyword animation borderangle,0: \
    #            keyword decoration:shadow:enabled 0;\
    #            keyword decoration:blur:enabled 0;\
    #            keyword decoration:fullscreen_opacity 1;\
    #            keyword general:gaps_in 0;\
    #            keyword general:gaps_out 0;\
    #            keyword general:border_size 1;\
    #            keyword decoration:rounding 0"
    #    fi
    PRE_STATUS_HOLDER="$(mktemp /tmp/DnD.pre.XXX)"
    if calculate-current-DnD "$PRE_STATUS_HOLDER"; then
        PREDND="$(<"$PRE_STATUS_HOLDER")"
        [[ $PREDND == true ]] || hyprexec dms ipc notifications toggleDoNotDisturb
    fi
}

main() {
    trap post EXIT INT TERM

    local -a cmd=("${FIXEDWRAPPERS[@]}")
    cmd+=(
        scopebuddy
        --
        "$@"
    )
    "${cmd[@]}"
}

post() {
    local post_status_holder
    hyprctl reload
    post_status_holder="$(mktemp /tmp/DnD.post.XXX)"
    if [[ $PREDND ]] && calculate-current-DnD "$post_status_holder"; then
        [[ $PREDND == "$(<"$post_status_holder")" ]] || hyprexec dms ipc notifications toggleDoNotDisturb
    fi
    rm -vf "$PRE_STATUS_HOLDER" "$post_status_holder"
}

pre
main "$@"
{{- end -}}

