{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash

NAME="$(basename "$0")"

help() {
    cat <<EOF
Usage:
    $NAME [COMMAND] [ARGUMENT...]

Commands:
    upgrade|--update|-u
        Sync package state declared in metapac groups.
    --help|-h
        Show this help and exit.
    <anything else>
        Passed through to metapac as-is.

Examples:
    $NAME upgrade
    $NAME unmanaged
    $NAME sync
EOF
}

case ${1:-} in
    --help|-h)
        help
        ;;
    --update|-u|upgrade)
        shift
        metapac sync "$@"
        ;;
    "")
        help
        exit 1
        ;;
    *)
        metapac "$@"
        ;;
esac

{{- end -}}
