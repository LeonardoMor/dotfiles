{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash

# Configure greetd
GREETD_CONFIG="/etc/greetd/config.toml"

hyprcmd='agreety --cmd start-hyprland' dasel --in toml --out toml --root \
    'if (default_session.command != $hyprcmd) {
        default_session.command = $hyprcmd
    } else {
        $root
    }' <"$GREETD_CONFIG" | sudo tee "$GREETD_CONFIG.tmp" >/dev/null
if [[ -s ${GREETD_CONFIG}.tmp ]]; then
    sudo mv "$GREETD_CONFIG.tmp" "$GREETD_CONFIG"
else
    sudo rm -f "$GREETD_CONFIG.tmp"
fi

[[ $(findmnt -no SOURCE /) =~ luks ]] && {
    dasel -i toml -o toml '$root.{
        $root...,
        "initial_session": {
            "command": "start-hyprland",
            "user": "{{ .chezmoi.username }}"
        }
    }' <"$GREETD_CONFIG" |
        sudo tee "$GREETD_CONFIG.tmp" >/dev/null
    if [[ -s ${GREETD_CONFIG}.tmp ]]; then
        sudo mv "$GREETD_CONFIG.tmp" "$GREETD_CONFIG"
    else
        sudo rm -f "$GREETD_CONFIG.tmp"
    fi
}

# Configure PAM to unlock gnome-keyring on login
GREETD_PAM="/etc/pam.d/greetd"
grep -q pam_gnome_keyring "$GREETD_PAM" || {
    sudo sed -i '/^auth.*include.*system-local-login/a auth       optional     pam_gnome_keyring.so' "$GREETD_PAM"
    sudo sed -i '/^session.*include.*system-local-login/a session    optional     pam_gnome_keyring.so' "$GREETD_PAM"
}

# DankMaterialShell — install via dankinstall (headless)
DMS_SENTINEL=~/.local/share/danklinux/installed
if [[ ! -f $DMS_SENTINEL ]]; then
    arch=$(uname -m)
    case $arch in
    x86_64) dl_arch=amd64 ;;
    aarch64) dl_arch=arm64 ;;
    *)
        echo "Unsupported arch: $arch" >&2
        exit 1
        ;;
    esac

    tmp=$(mktemp -d)
    trap 'rm -rf "$tmp"' EXIT

    base="https://github.com/AvengeMedia/DankMaterialShell/releases/latest/download"
    curl -fsSL "$base/dankinstall-${dl_arch}.gz" -o "$tmp/dankinstall.gz"
    curl -fsSL "$base/dankinstall-${dl_arch}.gz.sha256" -o "$tmp/dankinstall.gz.sha256"

    expected=$(awk '{print $1}' "$tmp/dankinstall.gz.sha256")
    actual=$(sha256sum "$tmp/dankinstall.gz" | awk '{print $1}')
    if [[ $expected != "$actual" ]]; then
        echo "dankinstall checksum mismatch" >&2
        exit 1
    fi

    gunzip "$tmp/dankinstall.gz"
    chmod +x "$tmp/dankinstall"

    # Cache sudo so the installer's privileged steps don't prompt mid-run.
    sudo -v

    "$tmp/dankinstall" \
        -c hyprland \
        -t ghostty \
        --include-deps dms-greeter \
        -y

    mkdir -p "$(dirname "$DMS_SENTINEL")"
    touch "$DMS_SENTINEL"
fi
{{- end -}}
