{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash

set -euo pipefail

# DankMaterialShell — install via dankinstall (headless)
DMS_SENTINEL=~/.local/share/danklinux/installed
[[ -f $DMS_SENTINEL ]] || {
    arch=$(uname -m)
    case $arch in
    x86_64) dl_arch=amd64 ;;
    aarch64) dl_arch=arm64 ;;
    *)
        echo "Unsupported arch: $arch" >&2
        exit 1
        ;;
    esac

    tmp=$(mktemp -d)
    trap 'rm -rf "$tmp"' EXIT

    base="https://github.com/AvengeMedia/DankMaterialShell/releases/latest/download"
    curl -fsSL "$base/dankinstall-${dl_arch}.gz" -o "$tmp/dankinstall.gz"
    curl -fsSL "$base/dankinstall-${dl_arch}.gz.sha256" -o "$tmp/dankinstall.gz.sha256"

    expected=$(awk '{print $1}' "$tmp/dankinstall.gz.sha256")
    actual=$(sha256sum "$tmp/dankinstall.gz" | awk '{print $1}')
    if [[ $expected != "$actual" ]]; then
        echo "dankinstall checksum mismatch" >&2
        exit 1
    fi

    gunzip "$tmp/dankinstall.gz"
    chmod +x "$tmp/dankinstall"

    # Cache sudo so the installer's privileged steps don't prompt mid-run.
    sudo -v

    "$tmp/dankinstall" \
        -c hyprland \
        -t ghostty \
        --include-deps dms-greeter \
        -y

    mkdir -p "$(dirname "$DMS_SENTINEL")"
    touch "$DMS_SENTINEL"
}

# Configure greetd via DMS
DMS_GREETER_SENTINEL=~/.local/share/danklinux/greeter-installed
[[ -f $DMS_GREETER_SENTINEL ]] || {
    sudo -v
    dms greeter install
    mkdir -p "$(dirname "$DMS_GREETER_SENTINEL")"
    sudo tee /etc/greetd/hypr.conf > /dev/null << 'EOF'
env = DMS_RUN_GREETER,1

misc {
    disable_hyprland_logo = true
}
EOF

    GREETD_CONFIG=/etc/greetd/config.toml
    sudo install -d /etc/greetd
    [[ -f $GREETD_CONFIG ]] || sudo tee "$GREETD_CONFIG" >/dev/null << 'EOF'
[terminal]
vt = ""

[default_session]
command = ""
user = "greeter"
EOF

    dmscmd='dms-greeter --command hyprland --config /etc/greetd/hypr.conf --remember-last-session true --remember-last-user true' \
        dasel --in toml --out toml --root \
        'if (terminal.vt != 1) {
            terminal.vt = 1
        } elseif (default_session.command != $dmscmd) {
            default_session.command = $dmscmd
        } elseif (default_session.user != "greeter") {
            default_session.user = "greeter"
        } else {
            $root
        }' <"$GREETD_CONFIG" | sudo tee "$GREETD_CONFIG.tmp" >/dev/null

    if [[ -s ${GREETD_CONFIG}.tmp ]]; then
        sudo mv "$GREETD_CONFIG.tmp" "$GREETD_CONFIG"
    else
        sudo rm -f "$GREETD_CONFIG.tmp"
    fi

    touch "$DMS_GREETER_SENTINEL"
}

