{{- if ne .chezmoi.os "windows" -}}
[cd]
command = "bash"
args = ["--login"]

{{ else -}}
[cd]
command = {{ or (lookPath "pwsh") (lookPath "powershell") | quote }}
args = ["-NoLogo"]

[interpreters]
ps1 = { command = {{ or (lookPath "pwsh") (lookPath "powershell") | quote }}, args = ["-NoLogo", "-NoProfile"] }

{{ end -}}
[edit]
command = "nvim"

[merge]
command = "nvim"
args = [
    "-d",
    {{ print "{{.Destination}}" | quote }},
    {{ print "{{.Source}}" | quote }},
    {{ print "{{.Target}}" | quote }},
]

[git]
autoPush = true
commitMessageTemplate = {{ print "{{ promptString \"Commit message\" }}" | quote }}

[onepassword]
prompt = true

{{ $osid := .chezmoi.os -}}
{{ if hasKey .chezmoi.osRelease "id" -}}
{{   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{ end -}}
{{ $workHost := "LMORACAS-M-D6L6" -}}
{{- $name := promptStringOnce . "name" "Full name" -}}
{{- $monitorProfile := "none" -}}
{{ if eq .chezmoi.os "linux" -}}
{{-   $monitorProfile = promptChoiceOnce . "monitorProfile" "External monitor profile" (list "none" "alienware" "asus-vg248") -}}
{{ end -}}
{{- $monitorModel := "" -}}
{{- if eq $monitorProfile "alienware" -}}{{ $monitorModel = "AW2725D" }}{{ end -}}
{{- if eq $monitorProfile "asus-vg248" -}}{{ $monitorModel = "VG248" }}{{ end -}}
[data]
osid = {{ $osid | quote }}
workHost = {{ $workHost | quote }}
name = {{ $name | quote }}
vaultsDir = {{ joinPath .chezmoi.homeDir "source" "repos" | quote }}
monitorProfile = {{ $monitorProfile | quote }}
monitorModel = {{ $monitorModel | quote }}
{{ if eq .chezmoi.hostname $workHost -}}
email = {{ onepasswordRead "op://Employee/workKey/add more/email" "cisco" | quote }}
{{ else -}}
email = {{ onepasswordRead "op://Private/personal_id_ed25519/add more/email" "my" | quote }}
{{ end -}}
{{ if eq $osid "darwin" -}}
brewPrefix = "/opt/homebrew"
packageManagers = { "brew" = { command = "brew", install = [
  "install",
  "--formula",
], update = [
  "update",
], upgrade = [
  "upgrade",
] }, "cask" = { command = "brew", install = [
  "install",
  "--cask",
], update = [
  "update",
], upgrade = [
  "upgrade",
  "--cask",
] } }
{{ end -}}
{{ if ne .chezmoi.os "windows" -}}
{{/*     XDG spec variables */ -}}
xdgConfigHome = "{{ .chezmoi.homeDir }}/.config"
xdgCacheHome = "{{ .chezmoi.homeDir }}/.cache"
xdgDataHome = "{{ .chezmoi.homeDir }}/.local/share"
xdgStateHome = "{{ .chezmoi.homeDir }}/.local/state"
xdgDataDirs = "/usr/local/share:/usr/share"
xdgConfigDirs = "/etc/xdg"
{{- end -}}

{{/*
vim: filetype=toml.gotmpl
*/}}
